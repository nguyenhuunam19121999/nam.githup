{
  "expo": {
    "name": "Mirai.JP",
    "slug": "mirai-jp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images_icon/Icon_loading.png",
    "scheme": "mirai-jp",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.miraijp.app",
      "supportsTablet": true,
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.miraijp.app",
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/withFirebaseModularHeadersFix.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images_icon/App_Icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "userTrackingUsageDescription": "Ứng dụng cần quyền này để hiển thị quảng cáo phù hợp hơn với sở thích của bạn.",
          "skAdNetworkItems": [
            "cstr6suwn9.skadnetwork",
            "4fzdc2evr5.skadnetwork",
            "4pfyvq9l8r.skadnetwork",
            "2fnua5tdw4.skadnetwork",
            "ydx93a7ass.skadnetwork"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9a67a07f-6ca6-43c4-b52d-9d7700a5cf7b"
      }
    },
    "owner": "nguyenhuunam312"
  }
}
