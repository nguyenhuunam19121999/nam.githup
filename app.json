{
  "expo": {
    "name": "Mirai",
    "slug": "mirai-jp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images_icon/Icon_loading-02.png",
    "scheme": "mirai-jp",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.miraijp.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Ứng dụng cần truy cập Camera để quét mã QR nhận điểm thưởng giới thiệu."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.miraijp.app",
      "permissions": [
        "android.permission.INTERNET",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.CAMERA"
      ],
      "googleServicesFile": "./google-services.json"
    },
        "plugins": [
      "expo-router",
      "@react-native-firebase/app/app.plugin.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.5"
          }
        }
      ],
      "./plugins/withFirebaseModularHeadersFix.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images_icon/Icon_loading.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "skAdNetworkItems": [
            "cstr6suwn9.skadnetwork",
            "4fzdc2evr5.skadnetwork",
            "4pfyvq9l8r.skadnetwork",
            "2fnua5tdw4.skadnetwork",
            "ydx93a7ass.skadnetwork"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9a67a07f-6ca6-43c4-b52d-9d7700a5cf7b"
      }
    },
    "owner": "nguyenhuunam312"
  }
}
